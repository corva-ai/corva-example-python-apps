srcs_comma_sep = src,tests,lambda_function.py
comma = ,
srcs = $(subst $(comma), ,$(srcs_comma_sep))
UV_SYNC = uv sync --frozen --group dev --no-install-project --no-editable
UV_RUN = uv run --frozen --group dev

## help: Show this help.
.PHONY: help
help: Makefile
	@sed -n 's/^##\s//p' $<

## install: Install all requirements.
.PHONY: install
install:
	@$(UV_SYNC)

## test: Run tests and and measure code coverage.
.PHONY: test
test:
	@$(UV_RUN) coverage run -m --branch --source=$(srcs_comma_sep) pytest tests

## testcov: Run tests and display code coverage in the browser.
.PHONY: testcov
testcov: test
	@$(UV_RUN) coverage html --precision=2 --skip-covered && x-www-browser htmlcov/index.html

## lint: Run static code analysis.
.PHONY: lint
lint:
	@$(UV_RUN) ruff check $(srcs)

## clean: Delete autogenerated files.
.PHONY: clean
clean:
	@-python3 -Bc "for p in __import__('pathlib').Path('.').rglob('*.py[co]'): p.unlink()"
	@-python3 -Bc "for p in __import__('pathlib').Path('.').rglob('__pycache__'): p.rmdir()"
	@-rm -rf .pytest_cache
	@-rm -rf htmlcov
	@-rm .coverage
